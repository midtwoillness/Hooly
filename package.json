{
  "name": "hooly-desktop",
  "version": "0.1.0",
  "description": "Floating desktop helper with image capture, AI summary, and todo generation",
  "main": "src/main/main.js",
  "scripts": {
    "dev": "electron .",
    "start": "electron .",
    "pack:mac": "electron-builder --mac",
    "pack:win": "electron-builder --win",
    "pack:linux": "electron-builder --linux"
  },
  "build": {
    "appId": "com.scq.hooly",
    "productName": "Hooly",
    "files": [
      "src/**/*",
      "package.json"
    ],
    "mac": {
      "target": "dmg"
    },
    "win": {
      "target": "nsis"
    },
    "linux": {
      "target": "AppImage"
    }
  },
  "devDependencies": {
    "electron": "^36.3.2",
    "electron-builder": "^24.13.3"
  }
}
